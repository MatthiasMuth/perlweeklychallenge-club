{
  "challenge": {
    "week": 373,
    "task": 1,
    "name": "Equal List"
  },
  "input_vars": [ "@arr1", "@arr2" ],
  "examples": [
    {
      "name": "Example 1",
      "in": [["a", "bc"], ["ab", "c"]],
      "out": [ true ]
    },
    {
      "name": "Example 2",
      "in": [["a", "b", "c"], ["a", "bc"]],
      "out": [ true ]
    },
    {
      "name": "Example 3",
      "in": [["a", "bc"], ["a", "c", "b"]],
      "out": [ false ]
    },
    {
      "name": "Example 4",
      "in": [["ab", "c", ""], ["", "a", "bc"]],
      "out": [ true ]
    },
    {
      "name": "Example 5",
      "in": [["p", "e", "r", "l"], ["perl"]],
      "out": [ true ]
    }
  ]
}
