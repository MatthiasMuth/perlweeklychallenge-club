#!/bin/bash

# Option and argument processing
while :; do
    case "$1" in
        [0-9]* )        challenge="$1";;
        json|-json )    PUBLISH_JSON=1;;
        * )             break;;
    esac
    shift
done

if [ ! "$challenge" ]; then
    last_challenge_dir="$( ls -d -r challenge-* | head -1 )"
    challenge="${last_challenge_dir##*-}"
fi

# Change into the toplevel directory.
toplevel="$( git rev-parse --show-toplevel )"
cd "$toplevel"

set -v

# Stash if necessary.
git update-index --refresh -q >/dev/null
if ! git diff-index --quiet HEAD --; then
    git stash
    stashed=1
fi

# Update all important branches.
set -e
# Update dev
git checkout dev
git pull

# Update master
git checkout master
git pull --ff-only

update=""
if [ "$PUBLISH_JSON" ]; then
    # Publish 'perl-json' directory to 'json-examples' branch.
    branch="json-examples"
    git switch "$branch" || git switch -c --orphan "$branch"

    source_dir="challenge-$challenge/matthias-muth/perl-json"
    target_dir="examples/challenge-$challenge"
    [ "$( git ls-tree -d --name-only HEAD -- "$source_dir" )" ] \
        && update=" - Update"

    mkdir -p "$target_dir"
    git ls-tree --name-only dev -- \
        "$source_dir"/ch-1.json \
        "$source_dir"/ch-1.pl \
        "$source_dir"/ch-2.json \
        "$source_dir"/ch-2.pl \
        | while read source_file; do
            target_file="$target_dir/${source_file##*/}"
            git show dev:"$source_file" > "$target_file"
        done

    msg="Challenge $challenge .json example data and Perl solution skeletons"
    git add "$target_dir"
    git commit -m "$msg$update" \
        || true
else
    # Publish solution.
    branch="muthm"
    git switch "$branch" || git switch -c "$branch"
    git merge --no-edit master

    dir="challenge-$challenge/matthias-muth"
    [ "$( git ls-tree -d --name-only $branch -- $dir/perl )" ] \
        && update=" - Update"

    git checkout dev -- \
        $( git ls-tree --name-only dev -- \
            "$dir"/README.md \
            "$dir"/blog.txt \
            "$dir"/perl/ch-1.pl \
            "$dir"/perl/ch-2.pl )

    echo "Activating testing section prepared for publishing"
    perl -i~ -g -n -E '
    /^# version for publishing/mi or do {
        warn "no '\''publishing'\'' template in '\''$ARGV'\''\n";
        print;
        next;
    };
    s<^use lib .*?\n^use MultiTest.*?\n>
        <use Test2::V0 qw( -no_srand );\n>ms;
    s<^run.*?\n.*Version for publishing.*use Test2::V.*?\n><>msi;
    print
    ' "$dir"/perl/ch-[12].pl
    git add -- "$dir"/perl/ch-[12].pl

    msg="Challenge $challenge Task 1 and 2 solutions in Perl by Matthias Muth"
    git commit -m "$msg$update" \
        || true
fi

git push --set-upstream origin "$branch"

git push --all
git push --tags

git checkout dev

if [ "$stashed" ]; then
    git stash pop
    git status -uno
fi
