{
  "challenge": {
    "week": 366,
    "task": 1,
    "name": "Count Prefixes"
  },
  "input_vars": [ "@array", "$str" ],
  "examples": [
    {
      "name": "Example 1",
      "in": [["a", "ap", "app", "apple", "banana"], "apple"],
      "out": [4]
    },
    {
      "name": "Example 2",
      "in": [["cat", "dog", "fish"], "bird"],
      "out": [0]
    },
    {
      "name": "Example 3",
      "in": [["hello", "he", "hell", "heaven", "he"], "hello"],
      "out": [4]
    },
    {
      "name": "Example 4",
      "in": [["", "code", "coding", "cod"], "coding"],
      "out": [3]
    },
    {
      "name": "Example 5",
      "in": [
        ["p", "pr", "pro", "prog", "progr", "progra", "program"],
        "program"
      ],
      "out": [7]
    }
  ]
}
